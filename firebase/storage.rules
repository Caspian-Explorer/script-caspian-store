rules_version = '2';

// Recommended Storage rules for a Caspian Store installation. Deploy with
//   firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {

    // Profile avatars live at users/{uid}/avatar.{ext}. Users upload their own;
    // anyone can read (product pages show them in review cards).
    match /users/{uid}/avatar.{ext} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
