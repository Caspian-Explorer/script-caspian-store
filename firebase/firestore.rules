rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin signal — claim-first, Firestore fallback. The Firebase Auth
    // custom claim `role` is the primary admin signal as of v8.4.1; the
    // Firestore read is a fallback for admins promoted before v8.4.1 (or
    // before their token has rotated to pick up the new claim). Storage
    // rules check the same predicate so consumer admin authorization
    // works identically across services.
    function isAdmin() {
      return request.auth != null
          && (request.auth.token.role == 'admin'
              || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isAuth() {
      return request.auth != null;
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /productCategories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /productBrands/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /productCollections/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{id} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      // On create: a user can write their own profile; role must be absent
      // or explicitly 'customer'. This is the only path — on first sign-in
      // resource.data is null, so the update-rule's role-equality check
      // (request.resource.data.role == resource.data.role) would fail
      // against null and silently deny the write, leaving userProfile null
      // in auth-context and every profile-dependent UI card blank.
      allow create: if isAuth() && request.auth.uid == uid
                    && (!('role' in request.resource.data) || request.resource.data.role == 'customer');
      // On update: role must stay as it is on the existing doc — blocks
      // self-promotion. Admin writes go through the isAdmin() branch below.
      allow update: if isAuth() && request.auth.uid == uid
                    && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
      allow read, write: if isAdmin();
    }

    match /carts/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /reviews/{id} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    match /questions/{id} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /promoCodes/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Shipping plugin installs — public read so the checkout calculator and
    // the public /shipping page can enumerate offered methods. Admin-only
    // write prevents shoppers from tampering with pricing.
    match /shippingPluginInstalls/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Payment plugin installs — public read so `useCheckout` on the storefront
    // can discover which provider to invoke. Only publishable (`pk_`-style)
    // credentials live here; server-side secrets are Cloud Functions secrets.
    // Admin-only write prevents shoppers from tampering with enabled providers.
    match /paymentPluginInstalls/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Email plugin installs — admin-only read AND write. The plugin config
    // stores the provider API key (SendGrid / Brevo). Cloud Functions read
    // via the Admin SDK, which bypasses rules. Shoppers never need to see
    // this collection, unlike shipping/payment installs. Added in v2.14.
    match /emailPluginInstalls/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /faqs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /journal/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pageContents/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /languages/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subscribers/{id} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Contact-form submissions (v2.13). Public create so unauthenticated
    // visitors can send a message; shape + length clamps blunt spam/abuse.
    // Admin-only read/update/delete — submissions are never shown publicly.
    // `status` is pinned to 'new' on create so the bell badge counts
    // everything that comes in; admins flip to 'read'/'archived'.
    match /contacts/{id} {
      allow create: if request.resource.data.status == 'new'
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 120
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000
                    && (!('subject' in request.resource.data)
                        || (request.resource.data.subject is string
                            && request.resource.data.subject.size() <= 200));
      allow read, update, delete: if isAdmin();
    }

    // Search-term analytics — storefront visitors upsert a doc per
    // normalized query (count + timestamps). Admin-only read/delete.
    // Shape is validated but writes are public: the data is analytics,
    // not security-sensitive, and forcing auth would drop anonymous
    // shoppers out of the funnel.
    match /searchTerms/{id} {
      allow read, delete: if isAdmin();
      allow create: if request.resource.data.term is string
                    && request.resource.data.term.size() > 0
                    && request.resource.data.term.size() <= 200
                    && request.resource.data.count == 1;
      allow update: if request.resource.data.term == resource.data.term
                    && request.resource.data.count is number
                    && request.resource.data.count > resource.data.count;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scriptSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin todo list — admins only for both read and write. Contains
    // internal setup/operational tasks, not shopper-facing content.
    match /adminTodos/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Setup-wizard email allowlist for the very first admin (v8.7.0).
    // Doc id is the lowercase, trimmed email. The wizard's "Designate by
    // email" path writes here BEFORE any admin exists; once the named
    // user signs up, `onUserCreate` promotes them and deletes the doc.
    //
    // - Public read so the wizard can confirm a designation already exists.
    // - Public create — but a doc can only be written ONCE per email
    //   (`!exists`), shape is validated, and the email must equal the
    //   doc id. The bigger safety invariant ("no admin exists yet") is
    //   enforced server-side in `onUserCreate`: if an admin already
    //   exists, the trigger ignores all pending entries, so a stale
    //   write here can't escalate privilege.
    // - Update forbidden — re-designate by delete + recreate.
    // - Delete restricted to admins (so post-install revocation goes
    //   through the admin panel; pre-install installers who fat-finger
    //   the email can fix it by signing up under the typo'd address
    //   to consume the entry, or by simply typing it correctly the
    //   second time — distinct emails create distinct docs).
    match /pendingSuperAdmin/{email} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/pendingSuperAdmin/$(email))
                    && request.resource.data.keys().hasOnly(['email', 'designatedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() <= 320
                    && request.resource.data.email == email;
      allow delete: if isAdmin();
    }

    // Transactional email config (v2.11). Admin-only on both read and write —
    // contains sender addresses, admin recipient lists, and unfiltered
    // template bodies that shouldn't leak to shoppers. Cloud Functions
    // bypass rules via the Admin SDK.
    match /emailSettings/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /emailTemplates/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Error logs (mod1182). Writes are public because crashes happen in
    // unauthenticated shopper sessions too — gate abuse with a strict shape
    // check (required scalar fields, capped string lengths, fixed source
    // enum, forbidden admin fields). Reads, updates, and deletes are
    // admin-only: the panel at /admin/about lists them, the admin dismisses
    // them, and the scheduled retention sweep trims them. Cloud Functions
    // write via the Admin SDK which bypasses rules entirely.
    match /errorLogs/{id} {
      allow create: if request.resource.data.source in ['client', 'service', 'cloud-function']
                    && request.resource.data.origin is string
                    && request.resource.data.origin.size() > 0
                    && request.resource.data.origin.size() <= 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 2000
                    && (!('stack' in request.resource.data)
                        || (request.resource.data.stack is string
                            && request.resource.data.stack.size() <= 4000))
                    && request.resource.data.libraryVersion is string
                    && request.resource.data.libraryVersion.size() <= 40
                    && request.resource.data.seenCount == 1;
      allow read, update, delete: if isAdmin();
    }
  }
}
