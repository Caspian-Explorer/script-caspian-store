{
  "name": "@caspian-explorer/script-caspian-store",
  "version": "0.6.0",
  "description": "Framework-agnostic React e-commerce store. Bring your own Firebase. Install into any React app (Next.js, Vite, CRA).",
  "license": "MIT",
  "author": "Caspian-Explorer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Caspian-Explorer/script-caspian-store.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles/globals.css",
    "firebase",
    "README.md",
    "INSTALL.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./firebase": {
      "types": "./dist/firebase/index.d.ts",
      "import": "./dist/firebase/index.js",
      "require": "./dist/firebase/index.cjs"
    },
    "./styles.css": "./src/styles/globals.css",
    "./firestore.rules": "./firebase/firestore.rules",
    "./firestore.indexes.json": "./firebase/firestore.indexes.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "firebase": "^11.0.0 || ^10.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "firebase": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
